# ===========================================
# Multi-Store SaaS Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# For Cloudflare, set these in wrangler.toml [vars] or Dashboard > Pages > Settings > Environment Variables

# --------------------------
# Cloudflare Configuration
# --------------------------
# Configured in wrangler.toml for production
# For local development, add to .env file
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_DATABASE_ID=your_database_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# --------------------------
# Cloudinary (Image Uploads)
# --------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --------------------------
# Session Secret
# --------------------------
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# --------------------------
# Email (Resend)
# --------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get your API key from https://resend.com/api-keys

# --------------------------
# AI (OpenRouter)
# --------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Get your API key from https://openrouter.ai/keys
# Model used: google/gemini-2.0-flash-001 (default)

# --------------------------
# Payment Gateways
# --------------------------

# bKash (Sandbox/Production)
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production URL: https://tokenized.pay.bka.sh/v1.2.0-beta

# Nagad (Sandbox/Production)
NAGAD_MERCHANT_ID=your_merchant_id
NAGAD_MERCHANT_NUMBER=your_merchant_number
NAGAD_PUBLIC_KEY=your_public_key
NAGAD_PRIVATE_KEY=your_private_key
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0
# Production URL: https://api.mynagad.com

# Stripe (International)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# --------------------------
# App URLs
# --------------------------
APP_URL=https://stores.digitalcare.site
# Local: http://localhost:5174

# --------------------------
# Optional: SMS (Future)
# --------------------------
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

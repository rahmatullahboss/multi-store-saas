{
  "name": "Luxe Boutique Page",
  "layout": "theme",
  "sections": {
    "header": {
      "type": "header",
      "settings": {
        "show_announcement": false,
        "show_search": true,
        "show_cart": true,
        "show_wishlist": true,
        "show_account": true,
        "menu_style": "minimal"
      }
    },
    "main": {
      "type": "rich-text",
      "settings": {
        "heading": "",
        "text": "",
        "text_alignment": "left",
        "container_width": "medium",
        "background_color": "#ffffff",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "footer": {
      "type": "footer",
      "settings": {
        "show_payment_icons": true,
        "show_social_links": true,
        "background_color": "#1a1a1a",
        "text_color": "#ffffff"
      }
    }
  },
  "order": ["header", "main", "footer"]
}

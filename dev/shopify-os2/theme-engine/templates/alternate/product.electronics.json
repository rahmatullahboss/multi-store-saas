{
  "name": "Product Page - Electronics",
  "layout": "theme",
  "extends": "product",
  "sections": {
    "header": {
      "id": "header",
      "type": "header",
      "settings": {}
    },
    "breadcrumb": {
      "id": "breadcrumb",
      "type": "breadcrumb",
      "settings": {
        "show_home": true,
        "separator": "chevron"
      }
    },
    "product-info": {
      "id": "product-info",
      "type": "product-info",
      "settings": {
        "layout": "image_left",
        "media_size": "large",
        "enable_zoom": true,
        "enable_video": true,
        "gallery_layout": "below",
        "show_quantity": true,
        "show_variant_labels": true,
        "variant_style": "buttons",
        "show_buy_now": true,
        "show_wishlist": true,
        "show_sku": true,
        "show_inventory": true,
        "show_share": true,
        "padding_top": 40,
        "padding_bottom": 40
      },
      "blocks": [
        {
          "id": "description",
          "type": "collapsible",
          "settings": {
            "heading": "Description",
            "icon": "none",
            "content": "",
            "open_by_default": true
          }
        },
        {
          "id": "warranty",
          "type": "custom_field",
          "settings": {
            "metafield_namespace": "product_info",
            "metafield_key": "warranty",
            "label": "Warranty"
          }
        },
        {
          "id": "power",
          "type": "custom_field",
          "settings": {
            "metafield_namespace": "product_info",
            "metafield_key": "power_specs",
            "label": "Power Requirements"
          }
        },
        {
          "id": "compatibility",
          "type": "custom_field",
          "settings": {
            "metafield_namespace": "product_info",
            "metafield_key": "compatibility",
            "label": "Compatibility"
          }
        },
        {
          "id": "shipping",
          "type": "collapsible",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "<p>Free shipping on orders over ৳1000. 7-day replacement warranty for manufacturing defects.</p>",
            "open_by_default": false
          }
        }
      ],
      "block_order": ["description", "warranty", "power", "compatibility", "shipping"]
    },
    "key-features": {
      "id": "key-features",
      "type": "key-features",
      "settings": {
        "heading": "Key Features",
        "layout": "grid",
        "columns": 3,
        "show_icons": true,
        "metafield_key": "product_info.key_features",
        "padding_top": 40,
        "padding_bottom": 40
      }
    },
    "specifications": {
      "id": "specifications",
      "type": "specifications-table",
      "settings": {
        "heading": "Technical Specifications",
        "layout": "table",
        "metafield_namespace": "product_info",
        "show_all": true,
        "grouped": true,
        "padding_top": 40,
        "padding_bottom": 40
      }
    },
    "product-tabs": {
      "id": "product-tabs",
      "type": "product-tabs",
      "settings": {
        "tab_style": "underline",
        "show_description": true,
        "show_specifications": true,
        "show_reviews": true,
        "show_faq": true,
        "padding_top": 40,
        "padding_bottom": 40
      }
    },
    "comparison": {
      "id": "comparison",
      "type": "product-comparison",
      "settings": {
        "heading": "Compare Models",
        "show_for_metafield": "product_info.comparison_products",
        "max_products": 3,
        "show_price": true,
        "show_key_specs": true,
        "padding_top": 60,
        "padding_bottom": 40
      }
    },
    "frequently-bought": {
      "id": "frequently-bought",
      "type": "frequently-bought-together",
      "settings": {
        "heading": "Frequently Bought Together",
        "source": "metafield",
        "metafield_key": "product_info.accessories",
        "show_bundle_discount": true,
        "bundle_discount_percent": 10,
        "padding_top": 40,
        "padding_bottom": 40
      }
    },
    "related-products": {
      "id": "related-products",
      "type": "related-products",
      "settings": {
        "heading": "Similar Products",
        "subheading": "",
        "heading_size": "medium",
        "source": "auto",
        "products_count": 4,
        "columns": 4,
        "padding_top": 40,
        "padding_bottom": 60
      }
    },
    "footer": {
      "id": "footer",
      "type": "footer",
      "settings": {}
    }
  },
  "order": [
    "header",
    "breadcrumb",
    "product-info",
    "key-features",
    "specifications",
    "product-tabs",
    "comparison",
    "frequently-bought",
    "related-products",
    "footer"
  ]
}

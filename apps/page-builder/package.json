{
  "name": "page-builder",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "wrangler pages dev ./build/client",
    "deploy": "npm run build && wrangler pages deploy ./build/client --project-name=multi-store-saas-builder",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "drizzle-orm": "^0.38.0",
    "grapesjs": "^0.22.14",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-plugin-forms": "^2.0.6",
    "grapesjs-preset-webpage": "^1.0.3",
    "isbot": "^5.1.0",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "swiper": "^12.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@remix-run/dev": "^2.15.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "name": "page-builder",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "wrangler pages dev ./build/client",
    "deploy": "npm run build && wrangler pages deploy ./build/client --project-name=multi-store-saas-builder",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.16.7",
    "@remix-run/react": "^2.16.7",
    "grapesjs": "^0.22.8",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-plugin-forms": "^2.0.6",
    "isbot": "^5.1.26",
    "lucide-react": "^0.501.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@remix-run/dev": "^2.16.7",
    "@tailwindcss/vite": "^4.1.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.2.0",
    "wrangler": "^3.101.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

    "react-markdown": "^9.1.0",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@remix-run/dev": "^2.17.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",

# OpenRouter API Key# OpenRouter (for direct API access)
OPENROUTER_API_KEY=your_key_here

# Optional: override default model
# AI_MODEL=anthropic/claude-3.5-sonnet

# Arena Automation Backend (for free models)
# Change to your deployed URL in production
ARENA_API_URL=http://localhost:5001
ARENA_MODEL=claude-opus-4-6-thinking

# Public env vars (available in browser)
NEXT_PUBLIC_MAIN_API_URL=https://ozzyl.com
NEXT_PUBLIC_DEFAULT_STORE_ID=1
NEXT_PUBLIC_DEFAULT_PRODUCT_ID=1

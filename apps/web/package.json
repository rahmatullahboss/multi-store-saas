{
  "name": "@ozzyl/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "dev:wrangler": "wrangler dev",
    "build": "remix vite:build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier -c .",
    "format": "prettier -w .",
    "deploy": "npm run deploy:prod",
    "deploy:prod": "npm run build && wrangler deploy --env production --keep-vars",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "db:generate": "drizzle-kit generate",
    "db:bootstrap:local": "wrangler d1 execute multi-store-saas-db --local --file=../../packages/database/src/migrations/0001_initial_schema.sql && wrangler d1 execute multi-store-saas-db --local --file=../../packages/database/src/migrations/0002_seed_data.sql && wrangler d1 execute multi-store-saas-db --local --file=../../packages/database/src/migrations/0003_hybrid_mode.sql",
    "db:bootstrap:prod": "wrangler d1 execute multi-store-saas-db --file=../../packages/database/src/migrations/0001_initial_schema.sql && wrangler d1 execute multi-store-saas-db --file=../../packages/database/src/migrations/0002_seed_data.sql && wrangler d1 execute multi-store-saas-db --file=../../packages/database/src/migrations/0003_hybrid_mode.sql",
    "db:migrate:local": "wrangler d1 migrations apply multi-store-saas-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply multi-store-saas-db --remote",
    "db:migrate:unified": "tsx scripts/run-unified-migration.ts",
    "db:migrate:unified:dry-run": "tsx scripts/run-unified-migration.ts --dry-run",
    "db:export:prod": "mkdir -p tmp && wrangler d1 export multi-store-saas-db --remote --output ./tmp/prod-export.sql",
    "db:export:prod:schema": "mkdir -p tmp && wrangler d1 export multi-store-saas-db --remote --no-data --output ./tmp/prod-export.schema.sql",
    "db:integrity:prod": "wrangler d1 execute multi-store-saas-db --remote --file ./scripts/db-integrity-checks.sql",
    "db:integrity:staging": "wrangler d1 execute multi-store-saas-db-staging --remote --env staging --file ./scripts/db-integrity-checks.sql",
    "db:stamp-migrations:staging": "mkdir -p tmp && node ../../scripts/generate-d1-stamp-sql.mjs --migrations-dir ../../packages/database/src/migrations --up-to manual_agent_tables.sql --out ./tmp/stamp-migrations-all.sql && wrangler d1 execute multi-store-saas-db-staging --remote --file ./tmp/stamp-migrations-all.sql",
    "db:clone:prod-to-staging": "npm run db:export:prod:schema && printf 'PRAGMA foreign_keys=OFF;\\n' > ./tmp/prod-export.schema.wrapped.sql && cat ./tmp/prod-export.schema.sql >> ./tmp/prod-export.schema.wrapped.sql && printf '\\nPRAGMA foreign_keys=ON;\\n' >> ./tmp/prod-export.schema.wrapped.sql && wrangler d1 execute multi-store-saas-db-staging --remote --file ./tmp/prod-export.schema.wrapped.sql && npm run db:stamp-migrations:staging",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:contract": "vitest run tests/unit/api-contract.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:release": "npm run typecheck && npm run test",
    "test:all": "npm run lint && npm run typecheck && npm run test",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test e2e/smoke.test.ts --project=chromium",
    "e2e:smoke:full": "playwright test e2e/smoke.test.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "health:prod": "bash ./workers/health-check.sh --main",
    "health:staging": "MAIN_APP_URL=https://multi-store-saas-staging.rahmatullahzisan.workers.dev bash ./workers/health-check.sh --main",
    "smoke:staging": "node ./scripts/smoke-staging.mjs",
    "db:seed:staging-demo": "wrangler d1 execute multi-store-saas-db-staging --remote --env staging --file ./scripts/seed-staging-demo.sql",
    "ci:local": "npm run test:all && npm run e2e",
    "i18n:extract": "npx i18next-parser 'app/**/*.{ts,tsx}' --config i18next-parser.config.js",
    "i18n:scan": "npx i18next-parser 'app/**/*.{ts,tsx}' --config i18next-parser.config.js --fail-on-update"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.7.6",
    "@hono/zod-validator": "^0.7.6",
    "@monaco-editor/react": "^4.7.0",
    "@ozzyl/db": "^0.0.0",
    "@ozzyl/ui": "^0.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@remix-run/cloudflare": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@sentry/cloudflare": "^10.42.0",
    "@sentry/remix": "^10.42.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.4",
    "framer-motion": "^12.34.5",
    "graphql": "^16.13.0",
    "graphql-yoga": "^5.18.0",
    "hono": "^4.12.4",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "isbot": "^5.1.35",
    "jiti": "^2.6.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.562.0",
    "react-i18next": "^15.7.4",
    "react-is": "^18.3.1",
    "recharts": "^2.15.4",
    "remix-auth": "^3.7.0",
    "remix-auth-google": "^2.0.0",
    "remix-i18next": "^6.4.1",
    "remix-utils": "^7.7.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@cloudflare/workers-types": "^4.20260301.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@remix-run/dev": "^2.17.4",
    "@remix-run/testing": "^2.17.4",
    "@sentry/vite-plugin": "^4.9.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.8.3",
    "i18next-parser": "^9.0.2",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "^4.0.18",
    "wrangler": "^4.66.0",
    "yaml": "^2.8.2"
  }
}

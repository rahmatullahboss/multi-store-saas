{
  "name": "@ozzyl/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "dev:wrangler": "wrangler pages dev ./build/client --d1=DB --r2=R2",
    "build": "remix vite:build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier -c .",
    "format": "prettier -w .",
    "deploy": "npm run build && wrangler pages deploy ./build/client --project-name=multi-store-saas",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute multi-store-saas-db --local --file=../../packages/database/src/migrations/0001_initial_schema.sql && wrangler d1 execute multi-store-saas-db --local --file=../../packages/database/src/migrations/0002_seed_data.sql && wrangler d1 execute multi-store-saas-db --local --file=../../packages/database/src/migrations/0003_hybrid_mode.sql",
    "db:migrate:prod": "wrangler d1 execute multi-store-saas-db --file=../../packages/database/src/migrations/0001_initial_schema.sql && wrangler d1 execute multi-store-saas-db --file=../../packages/database/src/migrations/0002_seed_data.sql && wrangler d1 execute multi-store-saas-db --file=../../packages/database/src/migrations/0003_hybrid_mode.sql",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:all": "npm run lint && npm run typecheck && npm run test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "ci:local": "npm run test:all && npm run e2e",
    "i18n:extract": "npx i18next-parser 'app/**/*.{ts,tsx}' --config i18next-parser.config.js",
    "i18n:scan": "npx i18next-parser 'app/**/*.{ts,tsx}' --config i18next-parser.config.js --fail-on-update"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.7.4",
    "@hono/zod-validator": "^0.7.6",
    "@monaco-editor/react": "^4.7.0",
    "@ozzyl/db": "*",
    "@ozzyl/ui": "*",
    "@remix-run/cloudflare": "^2.15.0",
    "@remix-run/cloudflare-pages": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@sentry/cloudflare": "^10.38.0",
    "@sentry/remix": "^10.35.0",
    "@tiptap/extension-link": "^3.16.0",
    "@tiptap/extension-placeholder": "^3.16.0",
    "@tiptap/extension-text-align": "^3.16.0",
    "@tiptap/pm": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.38.0",
    "framer-motion": "^12.24.10",
    "graphql": "^16.12.0",
    "graphql-yoga": "^5.18.0",
    "hono": "^4.11.4",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "isbot": "^5.1.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-is": "^18.3.1",
    "recharts": "^2.15.3",
    "remix-auth": "^3.7.0",
    "remix-auth-google": "^2.0.0",
    "remix-i18next": "^6.4.1",
    "remix-utils": "^7.7.0",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "swiper": "^12.0.3",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@remix-run/dev": "^2.15.0",
    "@remix-run/testing": "^2.17.3",
    "@sentry/vite-plugin": "^4.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.1.0",
    "i18next-parser": "^9.0.2",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.53.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.16",
    "wrangler": "^3.114.17"
  }
}

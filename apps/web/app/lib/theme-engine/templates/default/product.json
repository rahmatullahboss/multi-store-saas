{
  "name": "Product Page",
  "layout": "theme",
  "sections": {
    "header": {
      "id": "header",
      "type": "header",
      "settings": {}
    },
    "breadcrumb": {
      "id": "breadcrumb",
      "type": "breadcrumb",
      "settings": {
        "show_home": true,
        "separator": "chevron"
      }
    },
    "product-info": {
      "id": "product-info",
      "type": "product-info",
      "settings": {
        "layout": "image_left",
        "media_size": "medium",
        "enable_zoom": true,
        "enable_video": true,
        "gallery_layout": "below",
        "show_quantity": true,
        "show_variant_labels": true,
        "variant_style": "buttons",
        "show_buy_now": true,
        "show_wishlist": true,
        "show_sku": false,
        "show_inventory": true,
        "show_share": true,
        "padding_top": 40,
        "padding_bottom": 40
      },
      "blocks": [
        {
          "id": "description",
          "type": "collapsible",
          "settings": {
            "heading": "Description",
            "icon": "none",
            "content": "",
            "open_by_default": true
          }
        },
        {
          "id": "shipping",
          "type": "collapsible",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "<p>Free shipping on orders over ৳1000. 7-day easy returns.</p>",
            "open_by_default": false
          }
        }
      ],
      "block_order": ["description", "shipping"]
    },
    "product-tabs": {
      "id": "product-tabs",
      "type": "product-tabs",
      "settings": {
        "tab_style": "underline",
        "show_description": true,
        "show_specifications": true,
        "show_reviews": true,
        "padding_top": 40,
        "padding_bottom": 40
      }
    },
    "related-products": {
      "id": "related-products",
      "type": "related-products",
      "settings": {
        "heading": "You May Also Like",
        "subheading": "",
        "heading_size": "medium",
        "source": "auto",
        "products_count": 4,
        "columns": 4,
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "recently-viewed": {
      "id": "recently-viewed",
      "type": "related-products",
      "settings": {
        "heading": "Recently Viewed",
        "subheading": "",
        "heading_size": "medium",
        "source": "recently_viewed",
        "products_count": 4,
        "columns": 4,
        "padding_top": 40,
        "padding_bottom": 60
      }
    },
    "footer": {
      "id": "footer",
      "type": "footer",
      "settings": {}
    }
  },
  "order": [
    "header",
    "breadcrumb",
    "product-info",
    "product-tabs",
    "related-products",
    "recently-viewed",
    "footer"
  ]
}

{
  "name": "Luxe Boutique Product",
  "layout": "theme",
  "sections": {
    "header": {
      "type": "header",
      "settings": {
        "show_announcement": false,
        "show_search": true,
        "show_cart": true,
        "show_wishlist": true,
        "menu_style": "minimal"
      }
    },
    "main": {
      "type": "product-main",
      "settings": {
        "image_position": "left",
        "enable_zoom": true,
        "show_category": true,
        "show_sku": true,
        "show_quantity_selector": true,
        "show_share": true,
        "show_trust_badges": true,
        "shipping_text": "Complimentary Shipping",
        "guarantee_text": "Authenticity Guaranteed",
        "return_text": "14-Day Returns"
      },
      "blocks": [
        {
          "id": "description",
          "type": "description",
          "settings": {
            "show_full": true
          }
        }
      ]
    },
    "related-products": {
      "type": "featured-collection",
      "settings": {
        "heading": "You May Also Like",
        "heading_bn": "আপনার ভালো লাগতে পারে",
        "products_to_show": 4,
        "columns": 4,
        "show_view_all": false,
        "background_color": "#faf9f7",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "footer": {
      "type": "footer",
      "settings": {
        "show_payment_icons": true,
        "show_social_links": true,
        "background_color": "#1a1a1a",
        "text_color": "#ffffff"
      }
    }
  },
  "order": ["header", "main", "related-products", "footer"]
}

{
  "name": "Luxe Boutique Home",
  "layout": "theme",
  "sections": {
    "header": {
      "id": "header",
      "type": "header",
      "settings": {
        "show_announcement": true,
        "announcement_text": "Free Shipping on Orders Over ৳5,000",
        "show_search": true,
        "show_cart": true,
        "show_wishlist": true,
        "show_account": true,
        "menu_style": "minimal"
      }
    },
    "hero": {
      "id": "hero",
      "type": "hero-banner",
      "settings": {
        "heading": "Timeless Elegance",
        "heading_bn": "চিরন্তন সৌন্দর্য",
        "subheading": "Discover our curated collection of luxury pieces",
        "subheading_bn": "আমাদের সংগ্রহ থেকে বেছে নিন বিলাসবহুল পণ্য",
        "button_text": "Shop Now",
        "button_text_bn": "এখনই কিনুন",
        "button_link": "/products",
        "overlay_opacity": 40,
        "text_alignment": "center",
        "height": "large",
        "show_gold_border": true
      }
    },
    "featured-collection": {
      "id": "featured-collection",
      "type": "featured-collection",
      "settings": {
        "heading": "Featured Collection",
        "heading_bn": "বিশেষ সংগ্রহ",
        "products_to_show": 8,
        "columns": 4,
        "show_view_all": true,
        "view_all_text": "View All",
        "view_all_text_bn": "সব দেখুন",
        "view_all_link": "/products",
        "background_color": "#ffffff",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "new-arrivals": {
      "id": "new-arrivals",
      "type": "featured-collection",
      "settings": {
        "heading": "New Arrivals",
        "heading_bn": "নতুন সংগ্রহ",
        "products_to_show": 4,
        "columns": 4,
        "show_view_all": true,
        "view_all_text": "Discover More",
        "view_all_text_bn": "আরও দেখুন",
        "view_all_link": "/collections/new-arrivals",
        "background_color": "#faf9f7",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "trust-badges": {
      "id": "trust-badges",
      "type": "trust-badges",
      "settings": {
        "heading": "",
        "show_border": false,
        "background_style": "transparent",
        "background_color": "#ffffff",
        "padding_top": 48,
        "padding_bottom": 48
      },
      "blocks": [
        {
          "id": "badge-1",
          "type": "badge",
          "settings": {
            "icon": "shield",
            "title": "Authentic Products",
            "description": "100% Genuine Guaranteed"
          }
        },
        {
          "id": "badge-2",
          "type": "badge",
          "settings": {
            "icon": "truck",
            "title": "Free Shipping",
            "description": "On orders over ৳5,000"
          }
        },
        {
          "id": "badge-3",
          "type": "badge",
          "settings": {
            "icon": "return",
            "title": "Easy Returns",
            "description": "7-day return policy"
          }
        },
        {
          "id": "badge-4",
          "type": "badge",
          "settings": {
            "icon": "headphones",
            "title": "Premium Support",
            "description": "Dedicated assistance"
          }
        }
      ]
    },
    "footer": {
      "id": "footer",
      "type": "footer",
      "settings": {
        "show_payment_icons": true,
        "show_social_links": true,
        "copyright_text": "All rights reserved",
        "background_color": "#1a1a1a",
        "text_color": "#ffffff"
      }
    }
  },
  "order": ["header", "hero", "featured-collection", "new-arrivals", "trust-badges", "footer"]
}

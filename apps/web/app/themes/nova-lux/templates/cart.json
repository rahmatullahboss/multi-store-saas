{
  "name": "Nova Lux Cart",
  "layout": "theme",
  "sections": {
    "header": {
      "type": "header",
      "settings": {
        "show_announcement": false,
        "show_search": true,
        "show_cart": false,
        "menu_style": "minimal"
      }
    },
    "hero": {
      "type": "hero-banner",
      "settings": {
        "heading": "Shopping Cart",
        "subheading": "Review your selected items before checkout.",
        "button_text": "",
        "button_link": "",
        "overlay_opacity": 20,
        "height": "small"
      }
    },
    "footer": {
      "type": "footer",
      "settings": {
        "show_powered_by": true,
        "show_trust_badges": true
      }
    }
  },
  "order": ["header", "hero", "footer"]
}

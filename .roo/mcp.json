{
  "mcpServers": {
    "cloudflare": {
      "command": "npx",
      "args": [
        "-y",
        "@cloudflare/mcp-server-cloudflare",
        "run",
        "474078d5f990169d7dadf4e1df83214a"
      ],
      "env": {
        "CLOUDFLARE_API_TOKEN": "SET_IN_ENV_NOT_HERE",
        "DEBUG": ""
      },
      "disabled": false,
      "disabledTools": [],
      "alwaysAllow": [
        "worker_get"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "expo-docs": {
      "command": "npx",
      "args": [
        "-y",
        "expo-docs-mcp"
      ],
      "env": {},
      "disabled": true
    },
    "dart-mcp-server": {
      "command": "dart",
      "args": [
        "mcp-server"
      ],
      "env": {},
      "disabled": true
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {
        "CONTEXT7_API_KEY": "SET_IN_ENV_NOT_HERE"
      }
    },
    "firebase-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "mcp"
      ],
      "env": {},
      "disabled": true
    }
  }
}
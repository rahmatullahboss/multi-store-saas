{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["update_section", "add_section", "remove_section", "update_theme"]
    },
    "sectionId": {
      "type": "string"
    },
    "updates": {
      "type": "object"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": ["action", "confidence"]
}

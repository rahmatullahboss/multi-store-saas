{
  "name": "ozzyl-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "turbo:build": "turbo build",
    "turbo:dev": "turbo dev",
    "turbo:lint": "turbo lint",
    "turbo:test": "turbo test",
    "turbo:typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "deploy:landing": "vercel --prod --yes"
  },
  "dependencies": {
    "hono": "^4.12.7",
    "react-is": "^18.3.1"
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "prettier": "^3.0.0",
    "turbo": "^2.8.13"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "esbuild": "0.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "packageManager": "npm@10.0.0"

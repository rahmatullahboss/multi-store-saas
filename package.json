{
  "name": "ozzyl-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "turbo:build": "turbo build",
    "turbo:dev": "turbo dev",
    "turbo:lint": "turbo lint",
    "turbo:test": "turbo test",
    "turbo:typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "deploy:landing": "vercel --prod --yes"
  },
  "dependencies": {
    "react-is": "^18.3.1"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.7.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "esbuild": "0.25.0",
    "react-is": "^18.3.1"
  },
  "packageManager": "npm@10.0.0"
}
